	uint64_t b_norm = b << b_shift;

	/* Integer part of quotient */
	uint64_t q_int = a_norm / b_norm;
	uint64_t q_rem = a_norm % b_norm;

	/* Saturate if result too large for Q31 */
	if (q_int > (uint64_t)INT32_MAX) {
		*out_raw = neg ? INT32_MIN : INT32_MAX;
		*out_shift = 31;
